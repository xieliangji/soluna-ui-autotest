{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.io.soluna.local/v1/element-catalog.schema.json",
  "title": "Soluna UI Autotest Element Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "elements"],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "description": {
      "type": "string"
    },
    "elements": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/element"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "element": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        {
          "required": ["strategy", "value"]
        },
        {
          "required": ["android"]
        },
        {
          "required": ["ios"]
        }
      ],
      "properties": {
        "strategy": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "value": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "args": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "parameterizedTextReason": {
          "$ref": "#/$defs/parameterizedTextReason"
        },
        "hardcodedTextReason": {
          "$ref": "#/$defs/hardcodedTextReason"
        },
        "android": {
          "$ref": "#/$defs/locator"
        },
        "ios": {
          "$ref": "#/$defs/locator"
        }
      }
    },
    "locator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "value"],
      "properties": {
        "strategy": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "value": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "args": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "parameterizedTextReason": {
          "$ref": "#/$defs/parameterizedTextReason"
        },
        "hardcodedTextReason": {
          "$ref": "#/$defs/hardcodedTextReason"
        }
      }
    },
    "parameterizedTextReason": {
      "const": "language_insensitive_text"
    },
    "hardcodedTextReason": {
      "const": "language_insensitive_text"
    }
  }
}
