{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.soluna-ui-autotest.local/v1/plan.schema.json",
  "title": "Soluna UI Autotest Plan DSL",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "deviceConfig", "stages"],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "name": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "version": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "parameters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/parameterFileRef"
      },
      "default": []
    },
    "fragmentRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fragmentFileRef"
      },
      "default": []
    },
    "setupFragments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "default": []
    },
    "setupActions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      },
      "default": []
    },
    "caseSetupFragments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "default": []
    },
    "caseSetupActions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      },
      "default": []
    },
    "caseTeardownFragments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "default": []
    },
    "caseTeardownActions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      },
      "default": []
    },
    "teardownFragments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "default": []
    },
    "teardownActions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      },
      "default": []
    },
    "deviceConfig": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "artifactStore": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "app": {
      "$ref": "#/$defs/app"
    },
    "defaults": {
      "$ref": "#/$defs/defaults"
    },
    "trace": {
      "$ref": "#/$defs/trace"
    },
    "localArtifacts": {
      "$ref": "#/$defs/localArtifacts"
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stage"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "parameterFileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "file"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "file": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "required": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "fragmentFileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "file"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "file": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "required": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "caseFileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "file": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "required": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "elementFileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "file"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "file": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "required": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "app": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "platform": {
          "enum": ["android", "ios"]
        },
        "reset": {
          "type": "boolean"
        }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "implicitWaitMs": {
          "type": "integer",
          "minimum": 0,
          "default": 5000
        },
        "actionWait": {
          "$ref": "#/$defs/wait"
        },
        "failureStrategy": {
          "$ref": "#/$defs/id"
        },
        "retryStrategy": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "screenshots": {
          "$ref": "#/$defs/traceScreenshots"
        }
      }
    },
    "traceScreenshots": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "beforeAction": {
          "enum": ["never", "onFailure"],
          "default": "onFailure"
        },
        "retainBeforeActionCount": {
          "type": "integer",
          "minimum": 1,
          "default": 5
        },
        "upload": {
          "enum": ["never", "onFailure"],
          "default": "onFailure"
        }
      }
    },
    "localArtifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cleanup": {
          "$ref": "#/$defs/localArtifactCleanup"
        }
      }
    },
    "localArtifactCleanup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": ["never", "after-upload-success"],
          "default": "never"
        }
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "anyOf": [
        {
          "required": ["cases"]
        },
        {
          "required": ["caseRefs"]
        }
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "initialState": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "setupFragments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "default": []
        },
        "setupActions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          },
          "default": []
        },
        "caseSetupFragments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "default": []
        },
        "caseSetupActions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          },
          "default": []
        },
        "caseTeardownFragments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "default": []
        },
        "caseTeardownActions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          },
          "default": []
        },
        "teardownFragments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "default": []
        },
        "teardownActions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          },
          "default": []
        },
        "caseRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/caseFileRef"
          },
          "default": []
        },
        "cases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/case"
          }
        }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "actions"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "dataRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameterFileRef"
          },
          "default": []
        },
        "elementRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/elementFileRef"
          },
          "default": []
        },
        "setupFragments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "default": []
        },
        "setupActions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          },
          "default": []
        },
        "caseSetupFragments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "default": []
        },
        "caseSetupActions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          },
          "default": []
        },
        "caseTeardownFragments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "default": []
        },
        "caseTeardownActions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          },
          "default": []
        },
        "teardownFragments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "default": []
        },
        "teardownActions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          },
          "default": []
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/action"
          }
        }
      }
    },
    "action": {
      "oneOf": [
        { "allOf": [{ "$ref": "#/$defs/tapAction" }, { "required": ["tap"] }] },
        { "allOf": [{ "$ref": "#/$defs/tapAction" }, { "required": ["click"] }] },
        { "allOf": [{ "$ref": "#/$defs/tapAction" }, { "required": ["点击"] }] },
        { "allOf": [{ "$ref": "#/$defs/tapAction" }, { "required": ["轻点"] }] },
        { "allOf": [{ "$ref": "#/$defs/inputAction" }, { "required": ["input"] }] },
        { "allOf": [{ "$ref": "#/$defs/inputAction" }, { "required": ["type"] }] },
        { "allOf": [{ "$ref": "#/$defs/inputAction" }, { "required": ["输入"] }] },
        { "allOf": [{ "$ref": "#/$defs/inputAction" }, { "required": ["录入"] }] },
        { "allOf": [{ "$ref": "#/$defs/restartAppAction" }, { "required": ["restartApp"] }] },
        { "allOf": [{ "$ref": "#/$defs/restartAppAction" }, { "required": ["restart"] }] },
        { "allOf": [{ "$ref": "#/$defs/restartAppAction" }, { "required": ["重启应用"] }] },
        { "allOf": [{ "$ref": "#/$defs/restartAppAction" }, { "required": ["重启App"] }] },
        { "allOf": [{ "$ref": "#/$defs/restartAppAction" }, { "required": ["重启APP"] }] },
        { "allOf": [{ "$ref": "#/$defs/getTextAction" }, { "required": ["getText"] }] },
        { "allOf": [{ "$ref": "#/$defs/getTextAction" }, { "required": ["readText"] }] },
        { "allOf": [{ "$ref": "#/$defs/getTextAction" }, { "required": ["saveText"] }] },
        { "allOf": [{ "$ref": "#/$defs/getTextAction" }, { "required": ["获取文本"] }] },
        { "allOf": [{ "$ref": "#/$defs/getTextAction" }, { "required": ["读取文本"] }] },
        { "allOf": [{ "$ref": "#/$defs/getTextAction" }, { "required": ["保存文本"] }] },
        { "allOf": [{ "$ref": "#/$defs/waitAction" }, { "required": ["wait"] }] },
        { "allOf": [{ "$ref": "#/$defs/waitAction" }, { "required": ["sleep"] }] },
        { "allOf": [{ "$ref": "#/$defs/waitAction" }, { "required": ["pause"] }] },
        { "allOf": [{ "$ref": "#/$defs/waitAction" }, { "required": ["等待"] }] },
        { "allOf": [{ "$ref": "#/$defs/waitAction" }, { "required": ["暂停"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertElementAttrEqualsAction" }, { "required": ["assertElementAttrEquals"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertElementAttrEqualsAction" }, { "required": ["elementAttrEquals"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertElementAttrEqualsAction" }, { "required": ["断言元素属性相等"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertElementAttrEqualsAction" }, { "required": ["元素属性相等"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertElementAttrEqualsAction" }, { "required": ["attrEquals"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertElementAttrEqualsAction" }, { "required": ["属性相等"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertElementAttrRegexMatchAction" }, { "required": ["assertElementAttrRegexMatch"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertElementAttrRegexMatchAction" }, { "required": ["elementAttrRegexMatch"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertElementAttrRegexMatchAction" }, { "required": ["attrRegexMatch"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertElementAttrRegexMatchAction" }, { "required": ["断言元素属性匹配"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertElementAttrRegexMatchAction" }, { "required": ["元素属性匹配"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertElementAttrRegexMatchAction" }, { "required": ["属性匹配"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertSourceRegexMatchAction" }, { "required": ["assertSourceRegexMatch"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertSourceRegexMatchAction" }, { "required": ["sourceRegexMatch"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertSourceRegexMatchAction" }, { "required": ["断言源码匹配"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertSourceRegexMatchAction" }, { "required": ["源码匹配"] }] },
        { "allOf": [{ "$ref": "#/$defs/screenshotAction" }, { "required": ["screenshot"] }] },
        { "allOf": [{ "$ref": "#/$defs/screenshotAction" }, { "required": ["截图"] }] },
        { "allOf": [{ "$ref": "#/$defs/screenshotAction" }, { "required": ["显式截图"] }] },
        { "allOf": [{ "$ref": "#/$defs/startScreenRecordingAction" }, { "required": ["startScreenRecording"] }] },
        { "allOf": [{ "$ref": "#/$defs/startScreenRecordingAction" }, { "required": ["startRecording"] }] },
        { "allOf": [{ "$ref": "#/$defs/startScreenRecordingAction" }, { "required": ["开始录屏"] }] },
        { "allOf": [{ "$ref": "#/$defs/startScreenRecordingAction" }, { "required": ["开始屏幕录制"] }] },
        { "allOf": [{ "$ref": "#/$defs/stopScreenRecordingAction" }, { "required": ["stopScreenRecording"] }] },
        { "allOf": [{ "$ref": "#/$defs/stopScreenRecordingAction" }, { "required": ["stopRecording"] }] },
        { "allOf": [{ "$ref": "#/$defs/stopScreenRecordingAction" }, { "required": ["停止录屏"] }] },
        { "allOf": [{ "$ref": "#/$defs/stopScreenRecordingAction" }, { "required": ["停止屏幕录制"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertScreenRecordingTextRegexMatchAction" }, { "required": ["assertScreenRecordingTextRegexMatch"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertScreenRecordingTextRegexMatchAction" }, { "required": ["screenRecordingTextRegexMatch"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertScreenRecordingTextRegexMatchAction" }, { "required": ["断言录屏文本匹配"] }] },
        { "allOf": [{ "$ref": "#/$defs/assertScreenRecordingTextRegexMatchAction" }, { "required": ["录屏文本匹配"] }] },
        { "$ref": "#/$defs/nestedAction" }
      ]
    },
    "nestedAction": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "maxProperties": 1,
      "properties": {
        "tap": { "$ref": "#/$defs/nestedActionBody" },
        "click": { "$ref": "#/$defs/nestedActionBody" },
        "点击": { "$ref": "#/$defs/nestedActionBody" },
        "轻点": { "$ref": "#/$defs/nestedActionBody" },
        "tapVisualTemplate": { "$ref": "#/$defs/nestedActionBody" },
        "tapImage": { "$ref": "#/$defs/nestedActionBody" },
        "tapTemplate": { "$ref": "#/$defs/nestedActionBody" },
        "视觉点击": { "$ref": "#/$defs/nestedActionBody" },
        "模板点击": { "$ref": "#/$defs/nestedActionBody" },
        "图片点击": { "$ref": "#/$defs/nestedActionBody" },
        "input": { "$ref": "#/$defs/nestedActionBody" },
        "type": { "$ref": "#/$defs/nestedActionBody" },
        "输入": { "$ref": "#/$defs/nestedActionBody" },
        "录入": { "$ref": "#/$defs/nestedActionBody" },
        "restartApp": { "$ref": "#/$defs/nestedActionBody" },
        "restart": { "$ref": "#/$defs/nestedActionBody" },
        "重启应用": { "$ref": "#/$defs/nestedActionBody" },
        "重启App": { "$ref": "#/$defs/nestedActionBody" },
        "重启APP": { "$ref": "#/$defs/nestedActionBody" },
        "getText": { "$ref": "#/$defs/nestedActionBody" },
        "readText": { "$ref": "#/$defs/nestedActionBody" },
        "saveText": { "$ref": "#/$defs/nestedActionBody" },
        "获取文本": { "$ref": "#/$defs/nestedActionBody" },
        "读取文本": { "$ref": "#/$defs/nestedActionBody" },
        "保存文本": { "$ref": "#/$defs/nestedActionBody" },
        "wait": { "$ref": "#/$defs/nestedActionBody" },
        "sleep": { "$ref": "#/$defs/nestedActionBody" },
        "pause": { "$ref": "#/$defs/nestedActionBody" },
        "等待": { "$ref": "#/$defs/nestedActionBody" },
        "暂停": { "$ref": "#/$defs/nestedActionBody" },
        "assertElementAttrEquals": { "$ref": "#/$defs/nestedActionBody" },
        "elementAttrEquals": { "$ref": "#/$defs/nestedActionBody" },
        "attrEquals": { "$ref": "#/$defs/nestedActionBody" },
        "断言元素属性相等": { "$ref": "#/$defs/nestedActionBody" },
        "元素属性相等": { "$ref": "#/$defs/nestedActionBody" },
        "属性相等": { "$ref": "#/$defs/nestedActionBody" },
        "assertElementAttrRegexMatch": { "$ref": "#/$defs/nestedActionBody" },
        "elementAttrRegexMatch": { "$ref": "#/$defs/nestedActionBody" },
        "attrRegexMatch": { "$ref": "#/$defs/nestedActionBody" },
        "断言元素属性匹配": { "$ref": "#/$defs/nestedActionBody" },
        "元素属性匹配": { "$ref": "#/$defs/nestedActionBody" },
        "属性匹配": { "$ref": "#/$defs/nestedActionBody" },
        "assertSourceRegexMatch": { "$ref": "#/$defs/nestedActionBody" },
        "sourceRegexMatch": { "$ref": "#/$defs/nestedActionBody" },
        "断言源码匹配": { "$ref": "#/$defs/nestedActionBody" },
        "源码匹配": { "$ref": "#/$defs/nestedActionBody" },
        "screenshot": { "$ref": "#/$defs/nestedActionBody" },
        "截图": { "$ref": "#/$defs/nestedActionBody" },
        "显式截图": { "$ref": "#/$defs/nestedActionBody" },
        "startScreenRecording": { "$ref": "#/$defs/nestedActionBody" },
        "startRecording": { "$ref": "#/$defs/nestedActionBody" },
        "开始录屏": { "$ref": "#/$defs/nestedActionBody" },
        "开始屏幕录制": { "$ref": "#/$defs/nestedActionBody" },
        "stopScreenRecording": { "$ref": "#/$defs/nestedActionBody" },
        "stopRecording": { "$ref": "#/$defs/nestedActionBody" },
        "停止录屏": { "$ref": "#/$defs/nestedActionBody" },
        "停止屏幕录制": { "$ref": "#/$defs/nestedActionBody" },
        "assertScreenRecordingTextRegexMatch": { "$ref": "#/$defs/nestedActionBody" },
        "screenRecordingTextRegexMatch": { "$ref": "#/$defs/nestedActionBody" },
        "断言录屏文本匹配": { "$ref": "#/$defs/nestedActionBody" },
        "录屏文本匹配": { "$ref": "#/$defs/nestedActionBody" }
      }
    },
    "nestedActionBody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "desc": { "$ref": "#/$defs/nonEmptyString" },
        "appId": { "$ref": "#/$defs/nonEmptyString" },
        "attr": { "$ref": "#/$defs/nonEmptyString" },
        "clearFirst": { "type": "boolean" },
        "durationMs": { "type": "integer", "minimum": 0 },
        "element": { "$ref": "#/$defs/nonEmptyString" },
        "elementXRatio": { "$ref": "#/$defs/ratio" },
        "elementYRatio": { "$ref": "#/$defs/ratio" },
        "expected": true,
        "pattern": { "$ref": "#/$defs/nonEmptyString" },
        "candidateMaxFrames": { "type": "integer", "minimum": 1 },
        "candidateStrategy": { "$ref": "#/$defs/frameCandidateStrategy" },
        "framesPerSecond": { "type": "number", "exclusiveMinimum": 0 },
        "maxFrames": { "type": "integer", "minimum": 1 },
        "resourceId": { "$ref": "#/$defs/id" },
        "roi": { "$ref": "#/$defs/roi" },
        "saveAs": { "$ref": "#/$defs/id" },
        "scope": { "enum": ["plan", "case"] },
        "scales": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "number", "exclusiveMinimum": 0 }
        },
        "settleMs": { "type": "integer", "minimum": 0 },
        "source": { "$ref": "#/$defs/nonEmptyString" },
        "target": { "$ref": "#/$defs/nonEmptyString" },
        "targetXRatio": { "$ref": "#/$defs/ratio" },
        "targetYRatio": { "$ref": "#/$defs/ratio" },
        "template": { "$ref": "#/$defs/nonEmptyString" },
        "threshold": { "$ref": "#/$defs/ratio" },
        "timeLimitMs": { "type": "integer", "minimum": 1 },
        "timeoutMs": { "type": "integer", "minimum": 0 },
        "value": true,
        "visualDifferenceThreshold": { "type": "number", "minimum": 0 },
        "wait": { "$ref": "#/$defs/wait" },
        "xRatio": { "$ref": "#/$defs/ratio" },
        "yRatio": { "$ref": "#/$defs/ratio" }
      }
    },
    "tapAction": {
      "type": "object",
      "additionalProperties": false,
