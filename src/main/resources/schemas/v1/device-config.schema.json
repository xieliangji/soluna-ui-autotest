{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.soluna-ui-autotest.local/v1/device-config.schema.json",
  "title": "Soluna UI Autotest Per-device Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "device", "appium"],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": ["udid"],
      "properties": {
        "platform": {
          "enum": ["android", "ios"]
        },
        "udid": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "osVersion": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "appium": {
      "type": "object",
      "additionalProperties": false,
      "required": ["server"],
      "properties": {
        "server": {
          "type": "object",
          "additionalProperties": false,
          "required": ["managed"],
          "properties": {
            "managed": {
              "type": "boolean"
            },
            "url": {
              "type": "string",
              "minLength": 1
            },
            "host": {
              "type": "string"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "usePlugins": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": ["soluna-ext"]
            },
            "executable": {
              "type": "string",
              "minLength": 1,
              "default": "appium"
            },
            "extraArgs": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "environment": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "default": {}
            },
            "startupTimeoutMs": {
              "type": "integer",
              "minimum": 0,
              "default": 30000
            }
          }
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      }
    },
    "ios": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wda": {
          "$ref": "#/$defs/wda"
        }
      }
    }
  },
  "$defs": {
    "wda": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "managed": {
          "type": "boolean",
          "default": true
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "host": {
          "type": "string",
          "minLength": 1,
          "default": "127.0.0.1"
        },
        "hostPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "devicePort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 8100
        },
        "executable": {
          "type": "string",
          "minLength": 1,
          "default": "ios"
        },
        "tunnelMode": {
          "enum": ["userspace", "system"],
          "default": "userspace"
        },
        "tunnelInfoHost": {
          "type": "string",
          "minLength": 1,
          "default": "127.0.0.1"
        },
        "tunnelInfoPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "userspaceTunnelPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "bundleId": {
          "type": "string",
          "minLength": 1
        },
        "testRunnerBundleId": {
          "type": "string",
          "minLength": 1
        },
        "xctestConfig": {
          "type": "string",
          "minLength": 1
        },
        "extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "environment": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        },
        "startupTimeoutMs": {
          "type": "integer",
          "minimum": 0,
          "default": 60000
        },
        "tunnelStartupDelayMs": {
          "type": "integer",
          "minimum": 0,
          "default": 2000
        },
        "runwdaStartupDelayMs": {
          "type": "integer",
          "minimum": 0,
          "default": 2000
        }
      }
    }
  }
}
